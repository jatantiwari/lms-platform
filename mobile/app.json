{
  "expo": {
    "name": "ADI Boost",
    "slug": "adi-boost-student",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "adiboost",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#FFFFFF"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.alldigitalideas.adiboost",
      "infoPlist": {
        "NSCameraUsageDescription": "Used to upload your profile picture",
        "NSPhotoLibraryUsageDescription": "Used to select your profile picture",
        "NSMicrophoneUsageDescription": "Not required"
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#FFFFFF"
      },
      "package": "com.alldigitalideas.adiboost",
      "permissions": [
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE",
        "RECEIVE_BOOT_COMPLETED",
        "VIBRATE",
        "READ_PHONE_STATE",
        "READ_PHONE_NUMBERS",
        "SEND_SMS",
        "READ_SMS",
        "android.permission.MODIFY_AUDIO_SETTINGS"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-notifications",
        {
          "color": "#FF6B00",
          "sounds": []
        }
      ],
      [
        "expo-av",
        {
          "microphonePermission": false
        }
      ],
      "expo-video"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "02db826c-08eb-4d61-b7ff-5e7f2f91ae5e"
      }
    },
    "owner": "jatanadi"
  }
}
