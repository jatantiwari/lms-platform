// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum Role {
  STUDENT
  INSTRUCTOR
  ADMIN
}

enum CourseStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum CourseLevel {
  BEGINNER
  INTERMEDIATE
  ADVANCED
  ALL_LEVELS
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

enum InstructorStatus {
  PENDING
  APPROVED
  REJECTED
}

// ─── Models ───────────────────────────────────────────────────────────────────

model User {
  id             String    @id @default(cuid()) @map("_id")
  name           String
  email          String    @unique
  password       String
  role           Role      @default(STUDENT)
  avatar         String?
  bio            String?
  headline       String?
  website        String?
  phone          String?
  /// Original number set at registration — immutable after first phone verification
  originalPhone         String?
  /// Set to true after the one-time allowed phone number change
  isPhoneUpdated        Boolean   @default(false)
  phoneUpdatedAt        DateTime?
  refreshToken          String?
  emailVerified         Boolean   @default(false)
  verificationCode      String?
  verificationCodeExp   DateTime?
  resetToken            String?
  resetTokenExp         DateTime?
  phoneVerified         Boolean   @default(false)
  phoneOtpSession       String?   // 2Factor session ID (cleared after verification)
  /// Temp OTP session for device-trust verification (separate from account phone verify)
  deviceTrustOtpSession String?
  instructorApproved    Boolean   @default(false)
  isActive              Boolean   @default(true)
  pushToken             String?
  pushTokenPlatform     String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  // Relations
  courses                 Course[]           @relation("InstructorCourses")
  enrollments             Enrollment[]
  progress                Progress[]
  reviews                 Review[]
  lectureRatings          LectureRating[]
  deviceBindings          DeviceBinding[]    @relation("UserDevices")
  verificationLogs        VerificationLog[]
  phoneChangeLogs         PhoneChangeLog[]
  payments                Payment[]
  instructorProfile       InstructorProfile?
  seoRegistrations        SeoRegistration[]  @relation("StudentSeoReg")
  instructorSeoRegistrations SeoRegistration[] @relation("InstructorSeoReg")
  instructorSeoContactLeads SeoContactLead[] @relation("InstructorSeoContactLead")
  instructorSeoSubscribers  SeoSubscriber[]  @relation("InstructorSeoSubscriber")

  @@index([role])
  @@map("users")
}

// ─── Device Binding ───────────────────────────────────────────────────────────
// Stores hardware fingerprints bound to user sessions.
// Enables Google Pay-style device-bound authentication.

model DeviceBinding {
  id            String   @id @default(cuid()) @map("_id")
  userId        String

  /// Primary identifier — first 32 hex chars of SHA-256(ANDROID_ID|BUILD_FINGERPRINT|BOARD|HARDWARE)
  deviceId      String

  /// Full 64-char SHA-256 hash — used for timing-safe fingerprint comparison
  fingerprintHash String

  /// Android Build.FINGERPRINT (optional, for diagnostics)
  buildFingerprint String?

  model         String?
  manufacturer  String?
  sdkVersion    Int?
  osName        String?
  osVersion     String?
  platform      String   @default("android")  // android | ios | web

  isEmulator    Boolean  @default(false)
  isRooted      Boolean  @default(false)
  isDeveloperOptionsEnabled Boolean @default(false)

  /// Whether this device still needs phone OTP re-verification
  requiresReverification Boolean @default(true)

  /// Whether this device is fully trusted for course access
  isTrustedForCourseAccess Boolean @default(false)

  /// The mobile number that was successfully verified on this device
  verifiedMobileNumber  String?

  /// App version at time of last trust verification
  appVersion            String?

  /// Carrier / SIM metadata captured during verification
  carrierName           String?
  simSlotIndex          Int?

  /// How many times this device has been verified
  verificationCount     Int      @default(0)

  /// When device trust was last granted
  trustedAt             DateTime?

  /// Soft-delete: false = device revoked by user
  isActive      Boolean  @default(true)

  lastSeenAt    DateTime @default(now())
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user          User     @relation("UserDevices", fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, deviceId])
  @@map("device_bindings")
}

// ─── Verification Log ─────────────────────────────────────────────────────────
// Audit trail of every device trust verification attempt (pass and fail).

model VerificationLog {
  id              String   @id @default(cuid()) @map("_id")
  userId          String
  deviceId        String?
  deviceBindingId String?

  type            String   // DEVICE_TRUST_OTP | PHONE_CHANGE | ACCOUNT_PHONE_OTP
  status          String   // SUCCESS | FAILED | BLOCKED | EXPIRED

  /// Phone number the OTP was sent to (masked on read)
  phone           String?

  /// Reason for FAILED/BLOCKED
  failureReason   String?

  /// Request metadata for audit
  ipAddress       String?
  userAgent       String?
  platform        String?

  isRooted        Boolean? 
  isEmulator      Boolean?

  createdAt       DateTime @default(now())

  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, deviceId])
  @@map("verification_logs")
}

// ─── Phone Change Log ─────────────────────────────────────────────────────────
// Records the one-time phone number change per user.

model PhoneChangeLog {
  id            String   @id @default(cuid()) @map("_id")
  userId        String

  previousPhone String
  newPhone      String

  /// IP address at time of change
  ipAddress     String?
  platform      String?

  /// Verification that proved ownership of new number
  verifiedViaOtp Boolean @default(false)

  createdAt     DateTime @default(now())

  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("phone_change_logs")
}

model Category {
  id          String   @id @default(cuid()) @map("_id")
  name        String   @unique
  slug        String   @unique
  description String?
  icon        String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  courses Course[]

  @@map("categories")
}

model Course {
  id            String       @id @default(cuid()) @map("_id")
  title         String
  slug          String       @unique
  description   String
  shortDesc     String?
  thumbnail     String?
  previewVideo  String?      // HLS URL for course preview
  price         Float
  discountPrice Float?
  status        CourseStatus @default(DRAFT)
  level         CourseLevel  @default(BEGINNER)
  language      String       @default("English")
  tags          String[]     @default([])
  requirements  String[]     @default([])
  objectives    String[]     @default([])
  totalDuration Int          @default(0) // seconds
  totalLectures Int          @default(0)
  totalStudents Int          @default(0)
  avgRating     Float        @default(0)
  totalReviews  Int          @default(0)
  isFeatured    Boolean      @default(false)
  mobileOnly    Boolean      @default(false)

  // Relations
  instructorId String
  instructor   User       @relation("InstructorCourses", fields: [instructorId], references: [id], onDelete: Restrict)
  categoryId   String?
  category     Category?  @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  sections         Section[]
  enrollments      Enrollment[]
  reviews          Review[]
  payments         Payment[]
  seoRegistrations SeoRegistration[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([instructorId])
  @@index([status])
  @@index([categoryId])
  @@map("courses")
}

model Section {
  id        String    @id @default(cuid()) @map("_id")
  title     String
  order     Int       @default(0)
  courseId  String
  course    Course    @relation(fields: [courseId], references: [id], onDelete: Cascade)
  lectures  Lecture[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([courseId])
  @@map("sections")
}

model Lecture {
  id          String   @id @default(cuid()) @map("_id")
  title       String
  description String?
  order       Int      @default(0)
  duration    Int?     // seconds
  videoUrl    String?  // HLS .m3u8 streaming URL
  videoKey    String?  // S3 object key (original upload)
  hlsKey      String?  // S3 prefix for HLS segments
  isFree      Boolean  @default(false)
  isPublished Boolean  @default(false)
  resources   Json?    // array of {type, title, url, key?}
  questions   Json?    // array of LectureQuestion {id, question, options[], correctIndex, showAtSecond, explanation?}
  avgRating    Float   @default(0)
  totalRatings Int     @default(0)
  // Transcript (AWS Transcribe)
  transcriptJobName String?
  transcriptStatus  String?  // IN_PROGRESS | COMPLETED | FAILED
  transcript        String?

  sectionId String
  section   Section       @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  progress  Progress[]
  lectureRatings LectureRating[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([sectionId])
  @@map("lectures")
}

model Enrollment {
  id          String   @id @default(cuid()) @map("_id")
  userId      String
  courseId    String
  completedAt DateTime?

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, courseId])
  @@index([userId])
  @@index([courseId])
  @@map("enrollments")
}

model Progress {
  id             String  @id @default(cuid()) @map("_id")
  userId         String
  lectureId      String
  completed      Boolean @default(false)
  watchedSeconds Int     @default(0) // for resume functionality

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  lecture Lecture @relation(fields: [lectureId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, lectureId])
  @@index([userId])
  @@index([lectureId])
  @@map("progress")
}

model Review {
  id       String  @id @default(cuid()) @map("_id")
  rating   Int // 1-5
  comment  String?
  isHidden Boolean @default(false) // Admin moderation

  userId   String
  courseId String
  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  course   Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, courseId])
  @@index([courseId])
  @@index([rating])
  @@map("reviews")
}

model Payment {
  id                  String        @id @default(cuid()) @map("_id")
  amount              Float
  currency            String        @default("INR")
  status              PaymentStatus @default(PENDING)
  razorpayOrderId     String?       @unique
  razorpayPaymentId   String?
  razorpaySignature   String?
  failureReason       String?

  userId   String
  courseId String
  user     User   @relation(fields: [userId], references: [id], onDelete: Restrict)
  course   Course @relation(fields: [courseId], references: [id], onDelete: Restrict)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([courseId])
  @@index([status])
  @@map("payments")
}

model LectureRating {
  id        String  @id @default(cuid()) @map("_id")
  rating    Int     // 1-5
  userId    String
  lectureId String
  courseId  String  // denormalized for efficient course-level queries

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  lecture Lecture @relation(fields: [lectureId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, lectureId])
  @@index([lectureId])
  @@index([courseId])
  @@map("lecture_ratings")
}

model InstructorProfile {
  id                  String           @id @default(cuid()) @map("_id")
  userId              String           @unique
  user                User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  teachingExperience  String
  expertise           String[]
  bio                 String
  linkedIn            String?
  website             String?
  status              InstructorStatus @default(PENDING)
  rejectionReason     String?
  reviewedAt          DateTime?
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt

  @@index([status])
  @@map("instructor_profiles")
}

// ─── SEO Registration (from marketing site) ───────────────────────────────────

model SeoRegistration {
  id                          String        @id @default(cuid()) @map("_id")
  studentName                 String
  fatherGuardianName          String
  mobileNumber                String
  emailId                     String
  address                     String
  educationalQualification    String
  occupation                  String
  preferredCoursePlan         String        // "Basic" | "Pro" | "Elite"
  previousTradingExperience   String        // "Yes" | "No"
  whyJoin                     String
  amount                      Float
  paymentStatus               PaymentStatus @default(PENDING)
  razorpayOrderId             String?       @unique
  razorpayPaymentId           String?       @unique
  razorpaySignature           String?

  userId       String
  user         User    @relation("StudentSeoReg", fields: [userId], references: [id], onDelete: Cascade)
  instructorId String
  instructor   User    @relation("InstructorSeoReg", fields: [instructorId], references: [id], onDelete: Restrict)
  enrolledCourseId String?
  enrolledCourse   Course? @relation(fields: [enrolledCourseId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([instructorId])
  @@index([userId])
  @@index([paymentStatus])
  @@map("seo_registrations")
}

model SeoContactLead {
  id           String   @id @default(cuid()) @map("_id")
  fullName     String
  email        String
  phone        String?
  message      String
  instructorId String
  instructor   User     @relation("InstructorSeoContactLead", fields: [instructorId], references: [id], onDelete: Restrict)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([instructorId])
  @@index([email])
  @@map("seo_contact_leads")
}

model SeoSubscriber {
  id           String   @id @default(cuid()) @map("_id")
  email        String
  isActive     Boolean  @default(true)
  instructorId String
  instructor   User     @relation("InstructorSeoSubscriber", fields: [instructorId], references: [id], onDelete: Restrict)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([email, instructorId])
  @@index([instructorId])
  @@map("seo_subscribers")
}
